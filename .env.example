TEXT_PROVIDER=openai
LLM_BASE_URL=https://api.example.com
LLM_MODEL=your-model-name
LLM_API_KEY=your-api-key
LLM_TEMPERATURE=0.8

# Optional Gemini Web2API text adapter.
# Run Sophomoresty/gemini-web2api locally, then use:
# TEXT_PROVIDER=gemini_web2api
# LLM_BASE_URL=http://127.0.0.1:8081/v1
# LLM_MODEL=gemini-3.5-flash-thinking
# LLM_API_KEY=sk-local
GEMINI_WEB2API_BASE_URL=http://127.0.0.1:8081/v1
GEMINI_WEB2API_MODEL=gemini-3.5-flash-thinking
GEMINI_WEB2API_API_KEY=sk-local

IMAGE_PROVIDER=openai
IMAGE_BASE_URL=https://api.example.com
IMAGE_MODEL=your-image-model-name
IMAGE_API_KEY=your-image-api-key
IMAGE_SIZE=9:16

# Optional MiniMax T2A HTTP TTS adapter.
# API key is read from the MiniMax platform interface-key page.
TTS_PROVIDER=edge
MINIMAX_TTS_BASE_URL=https://api.minimaxi.com/v1/t2a_v2
MINIMAX_TTS_API_KEY=your-minimax-api-key
MINIMAX_TTS_GROUP_ID=
MINIMAX_TTS_MODEL=speech-2.8-hd
MINIMAX_TTS_VOICE_ID=male-qn-qingse
